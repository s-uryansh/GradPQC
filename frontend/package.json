{
  "name": "frontend",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "pnpm -r dev",
    "build": "pnpm -r build",
    "check-types": "pnpm -r --if-present check-types",
    "dev:native": "pnpm --filter native dev",
    "dev:web": "pnpm --filter web dev"
  },
  "dependencies": {
    "@frontend/env": "workspace:*",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "catalog:",
    "jose": "^6.2.2",
    "jsonwebtoken": "^9.0.3",
    "mysql": "^2.18.1",
    "mysql2": "^3.20.0",
    "react-hook-form": "^7.72.0",
    "recharts": "^3.8.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@frontend/config": "workspace:*",
    "@types/jsonwebtoken": "^9.0.10",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@10.32.1"
}
